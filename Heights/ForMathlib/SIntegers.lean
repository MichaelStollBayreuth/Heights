import Heights.ForMathlib.Basic
import Heights.ForMathlib.FractionalIdeal
import Mathlib

/-!
# The ring of `S`-integers is a Dedekind domain

Let `R` be a Dedekind domain with fraction field `K` and let `S` be a set of primes of `R`.
`Mathlib.RingTheory.DedekindDomain.SInteger` defines the subalgebra `Set.integer S K` of
`S`-integers, `ЁЭТк_S = {x : K | тИА v тИЙ S, v x тЙд 1} = тЛВ_{v тИЙ S} R_v`, but proves nothing about its
ring structure. This file develops it. The goal is:

* `ЁЭТк_S` is a Dedekind domain with fraction field `K`;
* its height one primes are exactly the `v тИЙ S`, via `v тЖж ЁЭТк_S тИй v`;
* its class group is `Cl(R)` modulo the subgroup generated by the classes of the `v тИИ S`.

These are the facts needed in `Heights.ForMathlib.SelmerGroup` to construct the right-hand map of the
fundamental exact sequence, and they reduce the whole exact sequence to the case `S = тИЕ`, where
the map to the class group is simply `x тЖж [ЁЭФЮ]` for the ideal with `ЁЭФЮ ^ n = (x)`. They are of
independent interest, and Mathlib has none of them.

## A warning

`ЁЭТк_S` is **not** in general a localization of `R`. Localizing at
`M = {r : R | r тЙа 0 тИз тИА v тИЙ S, v r = 1}` gives a subring of `ЁЭТк_S`, but it can be strictly
smaller: if `Cl(R) тЙЕ тДд` is generated by the class of a single prime `v` and `S = {v}`, then
`M = R╦г`, because no power `v ^ k` with `k тЙа 0` is principal; yet `ЁЭТк_S тКЛ R`, since for any
integral ideal `ЁЭФЮ` in the class of `v` the fractional ideal `ЁЭФЮ * vтБ╗┬╣` is principal, generated by
some `x` with `v x < 1` and `w x тЙд 1` for `w тЙа v`. So `ЁЭТк_S` has to be handled as a general
overring of `R`, not as a ring of fractions.

The classical statement in the appropriate generality is that *every* overring of a Dedekind
domain (i.e. every ring between `R` and `K`) is a Dedekind domain. The proofs below use the
`S`-integer description directly (via the denominator-ideal argument in `map_comap_eq`), which
keeps them short; upstreaming to Mathlib might instead aim for the general overring statement.

## Implementation notes

`Set.integer S K` is a `Subalgebra R K`. Since it sits between `R` and `K`, the instance
`Localization.subalgebra.instIsFractionRingSubtypeMemSubalgebra` already makes `K` its fraction
field, so `HeightOneSpectrum`-style valuation theory applies as soon as we know it is a Dedekind
domain.

## Main statements

* `IsDedekindDomain.SInteger.isIntegrallyClosed`: `ЁЭТк_S` is integrally closed.
* `IsDedekindDomain.SInteger.isDedekindDomain`: `ЁЭТк_S` is a Dedekind domain.
* `IsDedekindDomain.SInteger.heightOneSpectrumEquiv`: the primes of `ЁЭТк_S` are the `v тИЙ S`, and
  `valuation_heightOneSpectrumEquiv`: the valuations restrict those of `R`.
* `IsDedekindDomain.SInteger.extendedHom_surjective` and `finite_classGroup`: extension of ideals
  `Cl(R) тЖТ Cl(ЁЭТк_S)` is surjective, so `Cl(ЁЭТк_S)` is finite whenever `Cl(R)` is.
* `IsDedekindDomain.SInteger.classGroupEquiv`: `Cl(ЁЭТк_S) тЙГ* Cl(R) тз╕ тЯи[v] : v тИИ SтЯй`.

-/

open IsDedekindDomain FractionalIdeal

open scoped nonZeroDivisors Classical

section DenomIdeal

variable {R : Type*} [CommRing R] (K : Type*) [CommRing K] [Algebra R K]

/-- The denominator ideal of `x : K`: the colon ideal `(R : x) = {r : R | r тАв x тИИ R}`. -/
abbrev IsDedekindDomain.SInteger.denomIdeal (x : K) : Ideal R := (1 : Submodule R K).colon {x}

lemma IsDedekindDomain.SInteger.mem_denomIdeal_iff {x : K} {r : R} :
    r тИИ denomIdeal K x тЖФ тИГ s : R, algebraMap R K r * x = algebraMap R K s := by
  rw [Submodule.mem_colon_singleton, Algebra.smul_def, Submodule.mem_one]
  exact exists_congr fun s тЖж eq_comm

end DenomIdeal

namespace IsDedekindDomain.SInteger

variable {R : Type*} [CommRing R] [IsDedekindDomain R] (K : Type*) [Field K] [Algebra R K]
  [IsFractionRing R K] (S : Set (HeightOneSpectrum R))

lemma mem_integer_iff {x : K} : x тИИ S.integer K тЖФ тИА v тИЙ S, v.valuation K x тЙд 1 := Iff.rfl

lemma toSubring_le_valuationSubring {v : HeightOneSpectrum R} (hv : v тИЙ S) :
    (S.integer K).toSubring тЙд (v.valuation K).valuationSubring.toSubring :=
  fun _ hx тЖж hx v hv

/-- The fraction field of the ring of `S`-integers is `K`. This is already an instance, as
`Set.integer S K` is a subalgebra of `K` over `R`. -/
example : IsFractionRing (S.integer K) K := inferInstance

/-- The ring of `S`-integers is integrally closed: it is an intersection of valuation subrings
of `K`, each of which is integrally closed in `K`. -/
instance isIntegrallyClosed : IsIntegrallyClosed (S.integer K) := by
  rw [isIntegrallyClosed_iff K]
  intro x hx
  refine тЯитЯиx, fun v hv тЖж ?_тЯй, rflтЯй
  -- work inside the valuation subring `V` of `v`, which contains `ЁЭТк_S`
  set V := (v.valuation K).valuationSubring with hV
  let _ : Algebra (S.integer K) V :=
    (Subring.inclusion (toSubring_le_valuationSubring K S hv)).toAlgebra
  have _ : IsScalarTower (S.integer K) V K := .of_algebraMap_eq fun _ тЖж rfl
  obtain тЯиy, hyтЯй := (isIntegrallyClosed_iff K).mp inferInstance (hx.tower_top (A := V))
  rw [тЖР hy]
  exact y.property

/-!
### Primes in `S` become the unit ideal

For `v тИИ S` the inverse `vтБ╗┬╣` of `v` as a fractional ideal consists of `S`-integers, because an
element `y` with `y * v тКЖ R` can have a pole only at `v`. As `v * vтБ╗┬╣ = 1`, the extension of `v`
to `ЁЭТк_S` is therefore the unit ideal. This is the one place where the Dedekind property of `R`
enters, and it is what makes `ЁЭТк_S` bigger than `R`.
-/

/-- A height one prime is not contained in any other one. -/
lemma exists_mem_notMem {v w : HeightOneSpectrum R} (h : w тЙа v) :
    тИГ a тИИ v.asIdeal, a тИЙ w.asIdeal := by
  by_contra! hc
  exact h (HeightOneSpectrum.ext (v.isMaximal.eq_of_le w.isPrime.ne_top hc).symm)

/-- For `v тИИ S`, the fractional ideal `vтБ╗┬╣` consists of `S`-integers. -/
lemma mem_integer_of_mem_inv {v : HeightOneSpectrum R} (hv : v тИИ S) {y : K}
    (hy : y тИИ (v.asIdeal : FractionalIdeal RтБ░ K)тБ╗┬╣) : y тИИ S.integer K := by
  intro w hw
  obtain тЯиa, ha, hawтЯй := exists_mem_notMem (show w тЙа v by rintro rfl; exact hw hv)
  have h1 : y * algebraMap R K a тИИ (1 : FractionalIdeal RтБ░ K) :=
    (FractionalIdeal.mem_inv_iff (FractionalIdeal.coeIdeal_ne_zero.mpr v.ne_bot)).mp hy _
      (FractionalIdeal.mem_coeIdeal_of_mem RтБ░ ha)
  obtain тЯиr, hrтЯй := (FractionalIdeal.mem_one_iff _).mp h1
  have h2 : w.valuation K (y * algebraMap R K a) тЙд 1 := hr тЦ╕ w.valuation_le_one r
  rwa [map_mul, w.valuation_eq_one_iff_notMem.mpr haw, mul_one] at h2

/-- For `v тИИ S`, the extension of `v` to the ring of `S`-integers is the unit ideal. -/
lemma map_asIdeal_eq_top {v : HeightOneSpectrum R} (hv : v тИИ S) :
    Ideal.map (algebraMap R (S.integer K)) v.asIdeal = тКд := by
  set A := S.integer K with hA
  set M := Ideal.map (algebraMap R A) v.asIdeal with hM
  -- `1 тИИ v * vтБ╗┬╣`, as a submodule of `K`
  have h1 : (1 : K) тИИ
      (v.asIdeal : FractionalIdeal RтБ░ K) * (v.asIdeal : FractionalIdeal RтБ░ K)тБ╗┬╣ := by
    rw [FractionalIdeal.coe_ideal_mul_inv _ v.ne_bot]
    exact (FractionalIdeal.mem_one_iff _).mpr тЯи1, map_one _тЯй
  rw [тЖР FractionalIdeal.mem_coe, FractionalIdeal.coe_mul] at h1
  -- every element of the product that is an `S`-integer lies in `M`
  refine Ideal.eq_top_iff_one M |>.mpr ?_
  suffices H : тИА x тИИ (v.asIdeal : FractionalIdeal RтБ░ K) * (v.asIdeal : FractionalIdeal RтБ░ K)тБ╗┬╣,
      тИГ hx : x тИИ A, (тЯиx, hxтЯй : A) тИИ M by
    obtain тЯиhx, hx'тЯй := H 1 (by rwa [тЖР FractionalIdeal.coe_mul, FractionalIdeal.mem_coe] at h1)
    exact (show (тЯи1, hxтЯй : A) = 1 from rfl) тЦ╕ hx'
  intro x hx
  rw [тЖР FractionalIdeal.mem_coe, FractionalIdeal.coe_mul] at hx
  refine Submodule.mul_induction_on hx (fun a ha y hy тЖж ?_) (fun x y hx hy тЖж ?_)
  ┬╖ obtain тЯиa, ha', rflтЯй := (FractionalIdeal.mem_coeIdeal RтБ░).mp
      ((FractionalIdeal.mem_coe (I := (v.asIdeal : FractionalIdeal RтБ░ K))).mpr ha)
    have hyA : y тИИ A := mem_integer_of_mem_inv K S hv
      ((FractionalIdeal.mem_coe (I := (v.asIdeal : FractionalIdeal RтБ░ K)тБ╗┬╣)).mpr hy)
    have haA : algebraMap R K a тИИ A := A.algebraMap_mem a
    refine тЯиmul_mem haA hyA, ?_тЯй
    have he : (тЯиalgebraMap R K a * y, mul_mem haA hyAтЯй : A) = algebraMap R A a * тЯиy, hyAтЯй := rfl
    rw [he]
    exact Ideal.mul_mem_right _ M (Ideal.mem_map_of_mem _ ha')
  ┬╖ obtain тЯиhx, hx'тЯй := hx
    obtain тЯиhy, hy'тЯй := hy
    exact тЯиadd_mem hx hy, add_mem hx' hy'тЯй

/-!
### Ideals of `ЁЭТк_S` are extended from `R`

Let `I` be an ideal of `ЁЭТк_S` and `J = I тИй R` its contraction. For `x тИИ I` the denominator ideal
`ЁЭФб x = {r : R | r * x тИИ R}` is divisible only by primes in `S`, because `x` is `w`-integral for
`w тИЙ S`. Hence `ЁЭФб x * ЁЭТк_S = тКд` by `map_asIdeal_eq_top`, so `1 = тИС dс╡в cс╡в` with `dс╡в тИИ ЁЭФб x` and
`cс╡в тИИ ЁЭТк_S`, and `x = тИС (dс╡в * x) * cс╡в` exhibits `x` as an element of `J * ЁЭТк_S`, since
`dс╡в * x тИИ R тИй I = J`.

Noetherianity is immediate from this: `J` is finitely generated as `R` is Noetherian, hence so
is its extension `I`.
-/

/-- The denominator ideal of an `S`-integer is not contained in any prime off `S`: at such a
prime `x` is integral, so it has a denominator away from the prime. -/
lemma denomIdeal_not_le {x : K} (hx : x тИИ S.integer K) {w : HeightOneSpectrum R} (hw : w тИЙ S) :
    ┬м denomIdeal K x тЙд w.asIdeal := by
  obtain тЯиn, d, hndтЯй := HeightOneSpectrum.exists_primeCompl_mul_eq_of_integer w x (hx w hw)
  refine fun hle тЖж d.property (hle ?_)
  rw [mem_denomIdeal_iff]
  exact тЯиn, by rw [mul_comm]; exact hndтЯй

/-- The denominator ideal of any `x : K` is nonzero: a common denominator lies in it. -/
lemma denomIdeal_ne_bot (x : K) : denomIdeal K x тЙа (тКе : Ideal R) := by
  obtain тЯитЯиa, b, hbтЯй, habтЯй := IsLocalization.surj RтБ░ x
  refine fun h0 тЖж nonZeroDivisors.ne_zero hb ?_
  have : b тИИ denomIdeal K x := by rw [mem_denomIdeal_iff]; exact тЯиa, by rw [mul_comm]; exact habтЯй
  simpa [h0] using this

/-- The denominator ideal of an `S`-integer extends to the unit ideal of `ЁЭТк_S`: all its prime
factors lie in `S`, and each of those extends to the unit ideal by `map_asIdeal_eq_top`. -/
lemma map_denomIdeal_eq_top {x : K} (hx : x тИИ S.integer K) :
    Ideal.map (algebraMap R (S.integer K)) (denomIdeal K x) = тКд := by
  by_contra h
  obtain тЯиM, hM, hleтЯй := Ideal.exists_le_maximal _ h
  have hЁЭФнle : denomIdeal K x тЙд M.comap (algebraMap R (S.integer K)) :=
    (Ideal.le_comap_map).trans (Ideal.comap_mono hle)
  have hЁЭФнne : M.comap (algebraMap R (S.integer K)) тЙа тКе :=
    fun h0 тЖж denomIdeal_ne_bot K x (le_bot_iff.mp (h0 тЦ╕ hЁЭФнle))
  have hprime : (M.comap (algebraMap R (S.integer K))).IsPrime := hM.isPrime.comap _
  have hwS : (тЯи_, hprime, hЁЭФнneтЯй : HeightOneSpectrum R) тИИ S :=
    by_contra fun hwn тЖж denomIdeal_not_le K S hx hwn hЁЭФнle
  have htop := map_asIdeal_eq_top K S hwS
  exact hM.ne_top (top_le_iff.mp (htop.ge.trans Ideal.map_comap_le))

/-- **Every ideal of `ЁЭТк_S` is extended from `R`.** -/
theorem map_comap_eq (I : Ideal (S.integer K)) :
    Ideal.map (algebraMap R (S.integer K)) (I.comap (algebraMap R (S.integer K))) = I := by
  refine le_antisymm Ideal.map_comap_le fun x hx тЖж ?_
  set f := algebraMap R (S.integer K) with hf
  set J' := Ideal.map f (I.comap f) with hJ'
  have coeval (r : R) : ((f r : S.integer K) : K) = algebraMap R K r := by
    rw [IsScalarTower.algebraMap_apply R (S.integer K) K]; rfl
  -- for a denominator `d` of `x`, the product `f d * x` is extended from `R` and lies in `I`
  have key (d : R) (hd : d тИИ denomIdeal K (x : K)) : f d * x тИИ J' := by
    rw [mem_denomIdeal_iff] at hd
    obtain тЯиs, hsтЯй := hd
    have hfx : f d * x = f s := by
      apply Subtype.val_injective
      rw [Subalgebra.coe_mul, coeval d, coeval s, hs]
    rw [hfx]
    exact Ideal.mem_map_of_mem f (show f s тИИ I from hfx тЦ╕ I.mul_mem_left _ hx)
  -- the elements `r` with `r * x тИИ J'` form an ideal containing the extension of `denomIdeal`
  let K' : Ideal (S.integer K) :=
    { carrier := {r | r * x тИИ J'}
      zero_mem' := by simp
      add_mem' := fun {a b} ha hb тЖж by simpa [add_mul] using J'.add_mem ha hb
      smul_mem' := fun c {a} ha тЖж by
        simpa only [smul_eq_mul, Set.mem_setOf_eq, mul_assoc] using J'.mul_mem_left c ha }
  have hsub : Ideal.map f (denomIdeal K (x : K)) тЙд K' := Ideal.map_le_iff_le_comap.mpr key
  have hmtop : Ideal.map f (denomIdeal K (x : K)) = тКд := map_denomIdeal_eq_top K S x.property
  have h1 : (1 : S.integer K) * x тИИ J' := hsub (hmtop.ge Submodule.mem_top)
  simpa using h1

/-!
### The Dedekind property
-/

/-- The ring of `S`-integers is Noetherian: every ideal is extended from the Noetherian
ring `R` by `map_comap_eq`. -/
instance isNoetherianRing : IsNoetherianRing (S.integer K) := by
  refine (isNoetherianRing_iff_ideal_fg _).mpr fun I тЖж ?_
  rw [тЖР map_comap_eq K S I]
  exact Ideal.FG.map (IsNoetherian.noetherian (R := R) (I.comap (algebraMap R (S.integer K))))
    (algebraMap R (S.integer K))

/-- The contraction to `R` of a nonzero prime of `ЁЭТк_S` is a nonzero prime: if it were zero, the
prime would be `map тКе = тКе` by `map_comap_eq`. -/
lemma comap_ne_bot {P : Ideal (S.integer K)} (hP : P тЙа тКе) :
    P.comap (algebraMap R (S.integer K)) тЙа тКе := by
  intro h0
  exact hP (by rw [тЖР map_comap_eq K S P, h0, Ideal.map_bot])

/-- The ring of `S`-integers has Krull dimension at most `1`: the contraction to `R` of a
nonzero prime is maximal, and equalities of ideals lift back through `map_comap_eq`. -/
instance dimensionLEOne : Ring.DimensionLEOne (S.integer K) := by
  refine тЯиfun {P} hP hPp тЖж ?_тЯй
  set f := algebraMap R (S.integer K) with hf
  -- pass to a maximal ideal `M` above `P` and compare contractions in `R`
  obtain тЯиM, hM, hPMтЯй := P.exists_le_maximal hPp.ne_top
  have hcP : P.comap f тЙа тКе := comap_ne_bot K S hP
  have hMne : M тЙа тКе := fun h тЖж hP (le_bot_iff.mp (h тЦ╕ hPM))
  have hcM : M.comap f тЙа тКе := comap_ne_bot K S hMne
  -- both contractions are maximal in `R`, and one contains the other, so they are equal
  have hcPmax : (P.comap f).IsMaximal :=
    Ring.DimensionLEOne.maximalOfPrime hcP (hPp.comap f)
  have hcMprime : (M.comap f).IsPrime := hM.isPrime.comap f
  have heq : P.comap f = M.comap f :=
    hcPmax.eq_of_le hcMprime.ne_top (Ideal.comap_mono hPM)
  -- lift the equality back through `map_comap_eq`
  rwa [тЖР map_comap_eq K S P, heq, map_comap_eq K S M]

/-- **The ring of `S`-integers of a Dedekind domain is a Dedekind domain.** -/
instance isDedekindDomain : IsDedekindDomain (S.integer K) where

/-!
### The height one spectrum

The primes of `ЁЭТк_S` are the primes `v тИЙ S`, via `v тЖж ЁЭТк_S тИй v`. Under this correspondence the
`v`-adic valuation of `ЁЭТк_S` is the restriction of the `v`-adic valuation of `R`, so the Selmer
group of `ЁЭТк_S` relative to `тИЕ` is the Selmer group of `R` relative to `S`.
-/

/-- For `v тИЙ S`, the extension of `v` to `ЁЭТк_S` is a proper ideal: it is contained in the proper
ideal of `S`-integers with `v`-valuation `< 1` (which does not contain `1`). -/
lemma map_asIdeal_ne_top {v : HeightOneSpectrum R} (hv : v тИЙ S) :
    Ideal.map (algebraMap R (S.integer K)) v.asIdeal тЙа тКд := by
  set f := algebraMap R (S.integer K) with hf
  have coeval (r : R) : ((f r : S.integer K) : K) = algebraMap R K r := by
    rw [IsScalarTower.algebraMap_apply R (S.integer K) K]; rfl
  let ЁЭФк : Ideal (S.integer K) :=
    { carrier := {x | v.valuation K (x : K) < 1}
      zero_mem' := by simp
      add_mem' := fun {a b} ha hb тЖж by
        rw [Set.mem_setOf_eq, Subalgebra.coe_add]
        exact lt_of_le_of_lt ((v.valuation K).map_add _ _) (max_lt ha hb)
      smul_mem' := fun c {a} ha тЖж by
        have hc : v.valuation K (c : K) тЙд 1 := c.property v hv
        rw [Set.mem_setOf_eq, smul_eq_mul, Subalgebra.coe_mul, map_mul]
        calc v.valuation K (c : K) * v.valuation K (a : K)
            тЙд 1 * v.valuation K (a : K) := by gcongr
          _ = v.valuation K (a : K) := one_mul _
          _ < 1 := ha }
  have hle : Ideal.map f v.asIdeal тЙд ЁЭФк :=
    Ideal.map_le_iff_le_comap.mpr fun a ha тЖж by
      show v.valuation K ((f a : S.integer K) : K) < 1
      rw [coeval]; exact (v.valuation_lt_one_iff_mem a).mpr ha
  intro htop
  have h1 : v.valuation K ((1 : S.integer K) : K) < 1 := le_trans htop.ge hle Submodule.mem_top
  simp at h1

lemma comap_map_asIdeal {v : HeightOneSpectrum R} (hv : v тИЙ S) :
    (Ideal.map (algebraMap R (S.integer K)) v.asIdeal).comap (algebraMap R (S.integer K)) =
      v.asIdeal := by
  set f := algebraMap R (S.integer K) with hf
  refine (v.isMaximal.eq_of_le ?_ Ideal.le_comap_map).symm
  rw [Ne, Ideal.comap_eq_top_iff]
  exact map_asIdeal_ne_top K S hv

lemma isMaximal_map_asIdeal {v : HeightOneSpectrum R} (hv : v тИЙ S) :
    (Ideal.map (algebraMap R (S.integer K)) v.asIdeal).IsMaximal := by
  set f := algebraMap R (S.integer K) with hf
  obtain тЯиM, hM, hleтЯй := Ideal.exists_le_maximal _ (map_asIdeal_ne_top K S hv)
  have hcle : v.asIdeal тЙд M.comap f := (comap_map_asIdeal K S hv).ge.trans (Ideal.comap_mono hle)
  have hceq : M.comap f = v.asIdeal :=
    (v.isMaximal.eq_of_le (hM.isPrime.comap f).ne_top hcle).symm
  rwa [тЖР map_comap_eq K S M, hceq] at hM

/-- The extension of `v` to `ЁЭТк_S` is a nonzero ideal: `v` is nonzero and the map is injective. -/
lemma map_asIdeal_ne_bot {v : HeightOneSpectrum R} (hv : v тИЙ S) :
    Ideal.map (algebraMap R (S.integer K)) v.asIdeal тЙа тКе := by
  intro h
  refine v.ne_bot ?_
  rw [тЖР comap_map_asIdeal K S hv, h,
    Ideal.comap_bot_of_injective _ (FaithfulSMul.algebraMap_injective R (S.integer K))]

/-- The prime of `ЁЭТк_S` above a prime `v тИЙ S` of `R`: the extension of `v`. -/
noncomputable def primeOfNotMem {v : HeightOneSpectrum R} (hv : v тИЙ S) :
    HeightOneSpectrum (S.integer K) where
  asIdeal := Ideal.map (algebraMap R (S.integer K)) v.asIdeal
  isPrime := (isMaximal_map_asIdeal K S hv).isPrime
  ne_bot := map_asIdeal_ne_bot K S hv

@[simp] lemma primeOfNotMem_asIdeal {v : HeightOneSpectrum R} (hv : v тИЙ S) :
    (primeOfNotMem K S hv).asIdeal = Ideal.map (algebraMap R (S.integer K)) v.asIdeal :=
  rfl

/-- The prime of `R` below a prime `P` of `ЁЭТк_S`. -/
noncomputable def primeBelow (P : HeightOneSpectrum (S.integer K)) : HeightOneSpectrum R where
  asIdeal := P.asIdeal.comap (algebraMap R (S.integer K))
  isPrime := P.isPrime.comap _
  ne_bot := comap_ne_bot K S P.ne_bot

@[simp] lemma primeBelow_asIdeal (P : HeightOneSpectrum (S.integer K)) :
    (primeBelow K S P).asIdeal = P.asIdeal.comap (algebraMap R (S.integer K)) :=
  rfl

lemma primeBelow_notMem (P : HeightOneSpectrum (S.integer K)) : primeBelow K S P тИЙ S := by
  intro hv
  have h1 := map_asIdeal_eq_top K S hv
  rw [primeBelow_asIdeal, map_comap_eq] at h1
  exact P.isPrime.ne_top h1

/-- The primes of `ЁЭТк_S` are exactly the primes of `R` not in `S`. -/
noncomputable def heightOneSpectrumEquiv :
    {v : HeightOneSpectrum R // v тИЙ S} тЙГ HeightOneSpectrum (S.integer K) where
  toFun v := primeOfNotMem K S v.property
  invFun P := тЯиprimeBelow K S P, primeBelow_notMem K S PтЯй
  left_inv v := Subtype.ext <| HeightOneSpectrum.ext <| comap_map_asIdeal K S v.property
  right_inv P := HeightOneSpectrum.ext <| map_comap_eq K S P.asIdeal

@[simp] lemma heightOneSpectrumEquiv_apply (v : {v : HeightOneSpectrum R // v тИЙ S}) :
    heightOneSpectrumEquiv K S v = primeOfNotMem K S v.property :=
  rfl

@[simp] lemma heightOneSpectrumEquiv_symm_apply (P : HeightOneSpectrum (S.integer K)) :
    ((heightOneSpectrumEquiv K S).symm P : HeightOneSpectrum R) = primeBelow K S P :=
  rfl

/-- For `v тИЙ S`, the contraction of the extension of `v ^ n` is `v ^ n`: the contraction divides
`v ^ n`, so it is `v ^ j`; extending back gives `Pт▒╝ = PтВЩ`, whence `j = n`. -/
lemma comap_map_pow {v : HeightOneSpectrum R} (hv : v тИЙ S) (n : тДХ) :
    (Ideal.map (algebraMap R (S.integer K)) (v.asIdeal ^ n)).comap
        (algebraMap R (S.integer K)) = v.asIdeal ^ n := by
  set f := algebraMap R (S.integer K) with hf
  have hP0 : Ideal.map f v.asIdeal тЙа 0 := map_asIdeal_ne_bot K S hv
  have hPnu : ┬м IsUnit (Ideal.map f v.asIdeal) :=
    fun h тЖж map_asIdeal_ne_top K S hv (Ideal.isUnit_iff.mp h)
  refine le_antisymm ?_ Ideal.le_comap_map
  have hdvd : (Ideal.map f (v.asIdeal ^ n)).comap f тИг v.asIdeal ^ n :=
    Ideal.dvd_iff_le.mpr Ideal.le_comap_map
  obtain тЯиj, -, hassocтЯй := (dvd_prime_pow v.prime n).mp hdvd
  rw [associated_iff_eq] at hassoc
  have hmapQ : Ideal.map f ((Ideal.map f (v.asIdeal ^ n)).comap f) =
      Ideal.map f (v.asIdeal ^ n) := map_comap_eq K S _
  rw [hassoc, Ideal.map_pow, Ideal.map_pow] at hmapQ
  rw [hassoc, (pow_inj_of_not_isUnit hPnu hP0).mp hmapQ]

/-- For `v тИЙ S`, the `Pс╡е`-adic valuation on `R` (computed in `ЁЭТк_S`) is the `v`-adic valuation:
the two chains of prime powers `v ^ k` and `Pс╡е ^ k` have matching membership. -/
lemma intValuationDef_map {v : HeightOneSpectrum R} (hv : v тИЙ S) (a : R) :
    (primeOfNotMem K S hv).intValuationDef (algebraMap R (S.integer K) a) =
      v.intValuationDef a := by
  rcases eq_or_ne a 0 with rfl | ha
  ┬╖ simp
  have hfa : algebraMap R (S.integer K) a тЙа 0 := fun h тЖж ha
    (FaithfulSMul.algebraMap_injective R (S.integer K)
      (h.trans (map_zero (algebraMap R (S.integer K))).symm))
  have hmem (k : тДХ) : a тИИ v.asIdeal ^ k тЖФ
      algebraMap R (S.integer K) a тИИ (primeOfNotMem K S hv).asIdeal ^ k := by
    rw [primeOfNotMem_asIdeal, тЖР Ideal.map_pow, тЖР Ideal.mem_comap, comap_map_pow K S hv]
  suffices h : Associates.count (Associates.mk (primeOfNotMem K S hv).asIdeal)
        (Associates.mk (Ideal.span {algebraMap R (S.integer K) a})).factors =
      Associates.count (Associates.mk v.asIdeal) (Associates.mk (Ideal.span {a})).factors by
    rw [v.intValuationDef_if_neg ha, (primeOfNotMem K S hv).intValuationDef_if_neg hfa, h]
  refine Nat.le_antisymm ?_ ?_
  ┬╖ exact (v.le_count_iff ha _).mpr
      ((hmem _).mpr (((primeOfNotMem K S hv).le_count_iff hfa _).mp le_rfl))
  ┬╖ exact ((primeOfNotMem K S hv).le_count_iff hfa _).mpr
      ((hmem _).mp ((v.le_count_iff ha _).mp le_rfl))

/-- The valuation of `ЁЭТк_S` at the prime above `v` is the valuation of `R` at `v`. -/
lemma valuation_heightOneSpectrumEquiv (v : {v : HeightOneSpectrum R // v тИЙ S}) (x : K) :
    (heightOneSpectrumEquiv K S v).valuation K x = (v : HeightOneSpectrum R).valuation K x := by
  have hR (a : R) : (heightOneSpectrumEquiv K S v).valuation K (algebraMap R K a) =
      (v : HeightOneSpectrum R).valuation K (algebraMap R K a) := by
    have e1 : (heightOneSpectrumEquiv K S v).valuation K (algebraMap R K a) =
        (primeOfNotMem K S v.property).intValuationDef (algebraMap R (S.integer K) a) := by
      rw [IsScalarTower.algebraMap_apply R (S.integer K) K a,
        HeightOneSpectrum.valuation_of_algebraMap]; rfl
    rw [e1, intValuationDef_map K S v.property a, HeightOneSpectrum.valuation_of_algebraMap]; rfl
  obtain тЯиa, b, -, rflтЯй := IsFractionRing.div_surjective (A := R) x
  rw [map_divтВА, map_divтВА, hR a, hR b]

/-!
### The class group
-/

/-- `ЁЭТк_S` is torsion-free over `R`, as `R` embeds into it. -/
instance : Module.IsTorsionFree R (S.integer K) := by
  rw [Module.isTorsionFree_iff_algebraMap_injective]
  exact FaithfulSMul.algebraMap_injective R (S.integer K)

/-- Extension of ideals `Cl(R) тЖТ Cl(ЁЭТк_S)` is surjective: every ideal of `ЁЭТк_S` is extended from
`R` (`map_comap_eq`). -/
lemma extendedHom_surjective :
    Function.Surjective (ClassGroup.extendedHom R (S.integer K)) := by
  intro c
  obtain тЯиI, rflтЯй := ClassGroup.mk0_surjective c
  have hI : (I : Ideal (S.integer K)) тЙа тКе := by
    have := I.2; rwa [mem_nonZeroDivisors_iff_ne_zero] at this
  refine тЯиClassGroup.mk0 тЯи(I : Ideal (S.integer K)).comap (algebraMap R (S.integer K)),
    mem_nonZeroDivisors_iff_ne_zero.mpr (comap_ne_bot K S hI)тЯй, ?_тЯй
  rw [ClassGroup.extendedHom_mk0]
  exact congrArg _ (Subtype.ext (map_comap_eq K S _))

/-- The class group of `ЁЭТк_S` is finite as soon as that of `R` is, being a quotient of it. -/
instance finite_classGroup [Finite (ClassGroup R)] : Finite (ClassGroup (S.integer K)) :=
  .of_surjective _ (extendedHom_surjective K S)

/-- Divisibility by prime powers transfers along extension to `ЁЭТк_S` and back, for primes off
`S` (`comap_map_pow` for the reverse direction). -/
lemma map_le_map_pow_iff {v : HeightOneSpectrum R} (hv : v тИЙ S) (J : Ideal R) (k : тДХ) :
    Ideal.map (algebraMap R (S.integer K)) J тЙд (primeOfNotMem K S hv).asIdeal ^ k тЖФ
      J тЙд v.asIdeal ^ k := by
  rw [primeOfNotMem_asIdeal, тЖР Ideal.map_pow]
  exact тЯиfun h тЖж Ideal.le_comap_map.trans ((Ideal.comap_mono h).trans (comap_map_pow K S hv k).le),
    Ideal.map_monoтЯй

/-- The multiplicity of the extension of an ideal at the prime above `v тИЙ S` is the multiplicity
at `v`. -/
lemma count_map_coeIdeal {v : HeightOneSpectrum R} (hv : v тИЙ S) {J : Ideal R} (hJ : J тЙа тКе) :
    count K (primeOfNotMem K S hv)
        ((Ideal.map (algebraMap R (S.integer K)) J : Ideal (S.integer K)) :
          FractionalIdeal (S.integer K)тБ░ K) =
      count K v (J : FractionalIdeal RтБ░ K) := by
  have hmJ := Ideal.map_ne_bot_of_ne_bot (S := S.integer K) hJ
  rw [count_coe K _ hmJ, count_coe K v hJ, Nat.cast_inj]
  refine Nat.le_antisymm
    ((v.le_count_iff_le hJ _).mpr ((map_le_map_pow_iff K S hv J _).mp
      (((primeOfNotMem K S hv).le_count_iff_le hmJ _).mp le_rfl)))
    (((primeOfNotMem K S hv).le_count_iff_le hmJ _).mpr ((map_le_map_pow_iff K S hv J _).mpr
      ((v.le_count_iff_le hJ _).mp le_rfl)))

/-- The multiplicity of a principal fractional ideal at the prime above `v тИЙ S` is the
multiplicity at `v`, by the compatibility of valuations. -/
lemma count_spanSingleton_primeOfNotMem {v : HeightOneSpectrum R} (hv : v тИЙ S) (x : K╦г) :
    count K (primeOfNotMem K S hv) (spanSingleton (S.integer K)тБ░ (x : K)) =
      count K v (spanSingleton RтБ░ (x : K)) := by
  refine neg_injective (WithZero.exp_injective ?_)
  rw [тЖР valuation_eq_exp_neg_count _ x.ne_zero, тЖР valuation_eq_exp_neg_count v x.ne_zero]
  exact valuation_heightOneSpectrumEquiv K S тЯиv, hvтЯй (x : K)

/-- The classes of primes in `S` lie in the kernel of extension: such primes extend to `тКд`. -/
lemma closure_le_ker_extendedHom :
    Subgroup.closure (HeightOneSpectrum.classGroupMk '' S) тЙд
      (ClassGroup.extendedHom R (S.integer K)).ker := by
  rw [Subgroup.closure_le]
  rintro _ тЯиv, hv, rflтЯй
  rw [SetLike.mem_coe, MonoidHom.mem_ker, HeightOneSpectrum.classGroupMk,
    ClassGroup.extendedHom_mk0]
  refine (ClassGroup.mk0_eq_one_iff _).mpr ?_
  show (Ideal.map (algebraMap R (S.integer K)) v.asIdeal).IsPrincipal
  rw [map_asIdeal_eq_top K S hv]
  exact тЯи1, by simpтЯй

/-- The kernel of extension of ideal classes to `ЁЭТк_S` is contained in the subgroup generated by
the classes of the primes in `S`: if `map J = (x)` is principal, then `J` and the principal
fractional ideal `(x)` of `R` have the same valuations off `S` (`count_map_coeIdeal`,
`count_spanSingleton_primeOfNotMem`), so the class of `J` is a product of classes of primes in
`S` (`FractionalIdeal.mk0_mem_closure_of_count_eq`). -/
lemma ker_extendedHom_le :
    (ClassGroup.extendedHom R (S.integer K)).ker тЙд
      Subgroup.closure (HeightOneSpectrum.classGroupMk '' S) := by
  intro c hc
  obtain тЯиJ, rflтЯй := ClassGroup.mk0_surjective c
  rw [MonoidHom.mem_ker, ClassGroup.extendedHom_mk0, тЖР ClassGroup.mk_mk0 K,
    ClassGroup.mk_eq_one_iff_exists] at hc
  obtain тЯиx, hxтЯй := hc
  -- the generator found: `(x) = map J` over `ЁЭТк_S`
  have hxval : spanSingleton (S.integer K)тБ░ (x : K) =
      ((Ideal.map (algebraMap R (S.integer K)) (J : Ideal R) : Ideal (S.integer K)) :
        FractionalIdeal (S.integer K)тБ░ K) := by
    have h := congrArg Units.val hx
    rwa [coe_toPrincipalIdeal, FractionalIdeal.coe_mk0] at h
  refine FractionalIdeal.mk0_mem_closure_of_count_eq (x := x) fun v hv тЖж ?_
  rw [тЖР count_map_coeIdeal K S hv (mem_nonZeroDivisors_iff_ne_zero.mp J.2), тЖР hxval,
    count_spanSingleton_primeOfNotMem K S hv x]

/-- The kernel of extension is generated by the classes of the primes in `S`. -/
lemma ker_extendedHom :
    (ClassGroup.extendedHom R (S.integer K)).ker =
      Subgroup.closure (HeightOneSpectrum.classGroupMk '' S) :=
  le_antisymm (ker_extendedHom_le K S) (closure_le_ker_extendedHom K S)

/-- The class group of `ЁЭТк_S` is the class group of `R` modulo the classes of the primes in `S`:
the first isomorphism theorem applied to extension of ideals. -/
noncomputable def classGroupEquiv :
    ClassGroup (S.integer K) тЙГ*
      ClassGroup R тз╕ Subgroup.closure (HeightOneSpectrum.classGroupMk '' S) :=
  (QuotientGroup.quotientKerEquivOfSurjective _ (extendedHom_surjective K S)).symm.trans
    (QuotientGroup.quotientMulEquivOfEq (ker_extendedHom K S))

end IsDedekindDomain.SInteger
